<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="570.0" prefWidth="860.0"
           stylesheets="@../login.css"
           xmlns="http://javafx.com/javafx/25"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="application.controller.NewUserController">
    <children>

        <Pane fx:id="fundoParticulas"
              maxHeight="1.7976931348623157E308"
              maxWidth="1.7976931348623157E308"
              style="-fx-background-color: #0f1120;" />

        <VBox alignment="CENTER"
              maxHeight="1.7976931348623157E308"
              maxWidth="1.7976931348623157E308">
            <children>
                <HBox fx:id="card" maxWidth="-Infinity" prefHeight="500.0" prefWidth="830.0">
                    <children>

                        <VBox alignment="CENTER" prefHeight="500.0" prefWidth="236.0"
                              spacing="0" styleClass="painel-esquerdo">
                            <children>
                                <ImageView fitHeight="133.0" fitWidth="194.0"
                                           pickOnBounds="true" preserveRatio="true">
                                    <image>
                                        <Image url="@../../resources/imagens/TradeSystem-removebg-preview.png" />
                                    </image>
                                    <VBox.margin><Insets bottom="20.0" /></VBox.margin>
                                </ImageView>
                                <Label styleClass="titulo-painel" text="Novo Usuário">
                                    <VBox.margin><Insets bottom="8.0" /></VBox.margin>
                                </Label>
                                <Label styleClass="subtitulo-painel"
                                       text="Preencha os dados do funcionário"
                                       wrapText="true" />
                            </children>
                        </VBox>

                        <VBox alignment="CENTER" prefHeight="500.0" prefWidth="594.0"
                              styleClass="painel-form">
                            <children>

                                <Label styleClass="titulo-form" text="Cadastro de Funcionários" />

                                <Label styleClass="subtitulo-form"
                                       text="Preencha todos os campos abaixo">
                                    <VBox.margin><Insets bottom="20.0" /></VBox.margin>
                                </Label>

                                <HBox spacing="16">
                                    <VBox.margin><Insets bottom="14.0" /></VBox.margin>
                                    <children>
                                        <VBox HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="campo-label" text="NOME" />
                                                <HBox styleClass="campo-input"
                                                      alignment="CENTER_LEFT" spacing="8">
                                                    <children>
                                                        <Label text="&#xf007;" styleClass="campo-icone" />
                                                        <TextField fx:id="txtNome"
                                                                   promptText="Nome completo"
                                                                   styleClass="campo-input-interno">
                                                            <HBox.hgrow>
                                                                <Priority fx:constant="ALWAYS" />
                                                            </HBox.hgrow>
                                                        </TextField>
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                        <VBox HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="campo-label" text="CPF" />
                                                <HBox styleClass="campo-input"
                                                      alignment="CENTER_LEFT" spacing="8">
                                                    <children>
                                                        <Label text="&#xf2bb;" styleClass="campo-icone" />
                                                        <TextField fx:id="txtCpf"
                                                                   promptText="000.000.000-00"
                                                                   styleClass="campo-input-interno">
                                                            <HBox.hgrow>
                                                                <Priority fx:constant="ALWAYS" />
                                                            </HBox.hgrow>
                                                        </TextField>
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <HBox spacing="16">
                                    <VBox.margin><Insets bottom="14.0" /></VBox.margin>
                                    <children>
                                        <VBox HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="campo-label" text="EMAIL" />
                                                <HBox styleClass="campo-input"
                                                      alignment="CENTER_LEFT" spacing="8">
                                                    <children>
                                                        <Label text="&#xf0e0;" styleClass="campo-icone" />
                                                        <TextField fx:id="txtEmail"
                                                                   promptText="email@exemplo.com"
                                                                   styleClass="campo-input-interno">
                                                            <HBox.hgrow>
                                                                <Priority fx:constant="ALWAYS" />
                                                            </HBox.hgrow>
                                                        </TextField>
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                        <VBox HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="campo-label" text="SENHA" />
                                                <HBox styleClass="campo-input"
                                                      alignment="CENTER_LEFT" spacing="8">
                                                    <children>
                                                        <Label text="&#xf023;" styleClass="campo-icone" />
                                                        <TextField fx:id="txtSenha"
                                                                   promptText="Senha do usuário"
                                                                   styleClass="campo-input-interno">
                                                            <HBox.hgrow>
                                                                <Priority fx:constant="ALWAYS" />
                                                            </HBox.hgrow>
                                                        </TextField>
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <HBox spacing="16">
                                    <VBox.margin><Insets bottom="24.0" /></VBox.margin>
                                    <children>
                                        <VBox HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="campo-label" text="CNPJ" />
                                                <HBox styleClass="campo-input"
                                                      alignment="CENTER_LEFT" spacing="8">
                                                    <children>
                                                        <Label text="&#xf1ad;" styleClass="campo-icone" />
                                                        <TextField fx:id="txtCnpj"
                                                                   promptText="00.000.000/0000-00"
                                                                   styleClass="campo-input-interno">
                                                            <HBox.hgrow>
                                                                <Priority fx:constant="ALWAYS" />
                                                            </HBox.hgrow>
                                                        </TextField>
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                        <VBox HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="campo-label" text="FUNÇÃO" />
                                                <HBox styleClass="campo-input"
                                                      alignment="CENTER_LEFT" spacing="8">
                                                    <children>
                                                        <Label text="&#xf0b1;" styleClass="campo-icone" />
                                                        <MenuButton fx:id="MenuFuncao"
                                                                    text="Selecionar função"
                                                                    styleClass="campo-menu-interno">
                                                            <HBox.hgrow>
                                                                <Priority fx:constant="ALWAYS" />
                                                            </HBox.hgrow>
                                                            <items>
                                                                <MenuItem fx:id="ItemOperario" mnemonicParsing="false" text="Operário" />
                                                                <MenuItem fx:id="ItemEstoquista" mnemonicParsing="false" text="Estoquista" />
                                                                <MenuItem fx:id="ItemGerente" mnemonicParsing="false" text="Gerente" />
                                                                <MenuItem fx:id="ItemVendedor" mnemonicParsing="false" text="Vendedor" />
                                                            </items>
                                                        </MenuButton>
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <Button fx:id="btnCadastrar" onAction="#Salvar"
                                        prefHeight="42.0" prefWidth="180.0"
                                        styleClass="btn-entrar" text="Cadastrar">
                                    <VBox.margin><Insets bottom="12.0" /></VBox.margin>
                                </Button>


                                <Label fx:id="lblCancelar"
                                       styleClass="link-novo"
                                       text="Cancelar" />

                            </children>
                        </VBox>

                    </children>
                </HBox>
            </children>
        </VBox>

    </children>
</StackPane>