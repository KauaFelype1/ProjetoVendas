<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="650.0" prefWidth="850.0" style="-fx-background-color: #0f1120;" stylesheets="@../login.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.controller.SelectionUserController">

    <children>
        <BorderPane style="-fx-background-color: #0f1120;">
            <top>
                <VBox style="-fx-padding: 28 48 0 48; -fx-spacing: 10;">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Button fx:id="btnVoltar" onAction="#voltar" prefHeight="32" text="← Voltar" 
                                style="-fx-background-color: transparent; -fx-border-color: #2a3156; -fx-border-radius: 7; -fx-border-width: 1.5; -fx-text-fill: #8891bb; -fx-font-size: 12px; -fx-cursor: hand;" />
                        <Label text="Vendas" style="-fx-font-size: 12px; -fx-text-fill: #6b7099;" />
                        <Label text="›" style="-fx-font-size: 13px; -fx-text-fill: #3a4060;" />
                        <Label text="Seleção de Cliente" style="-fx-font-size: 12px; -fx-text-fill: #534AB7; -fx-font-weight: bold;" />
                    </HBox>

                    <HBox alignment="CENTER_LEFT">
                        <Label text="Selecionar" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #c5c8e8;" />
                        <Label text=" Cliente" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #534AB7;">
                            <HBox.margin><Insets left="8.0" /></HBox.margin>
                        </Label>
                    </HBox>

                    <Region prefHeight="1" style="-fx-background-color: #1e2540;">
                        <VBox.margin><Insets top="10" /></VBox.margin>
                    </Region>
                </VBox>
            </top>

            <center>
                <VBox spacing="20" style="-fx-padding: 24 48 36 48;">
                    
                    <VBox style="-fx-background-color: #1a1f36; -fx-background-radius: 14; -fx-border-color: #252b4a; -fx-border-radius: 14; -fx-padding: 25; -fx-spacing: 20;">
                        <HBox alignment="BOTTOM_LEFT" spacing="15">
                            <VBox spacing="7" HBox.hgrow="ALWAYS">
                                <Label text="BUSCAR CLIENTE" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #6b7099;" />
                                <TextField fx:id="txtBuscar" prefHeight="45" promptText="Digite nome ou CPF..." 
                                           style="-fx-background-color: #0d1028; -fx-background-radius: 9; -fx-border-color: #252b4a; -fx-text-fill: #c5c8e8; -fx-padding: 0 15;" />
                            </VBox>
                            <Button fx:id="btnBuscar" onAction="#Buscar" prefHeight="45" prefWidth="120" text="Pesquisar" 
                                    style="-fx-background-color: #252b4a; -fx-background-radius: 9; -fx-text-fill: #c5c8e8; -fx-font-weight: bold; -fx-cursor: hand;" />
                        </HBox>

                        <Region prefHeight="1" style="-fx-background-color: #252b4a;" />

                        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #0d1028; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #534AB7; -fx-border-width: 0 0 0 4;">
                            <VBox spacing="3">
                                <Label text="CLIENTE SELECIONADO" style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #534AB7;" />
                                <Label fx:id="lblNome" text="Nenhum cliente selecionado" style="-fx-font-size: 16px; -fx-text-fill: white; -fx-font-weight: bold;" />
                            </VBox>
                            <Pane HBox.hgrow="ALWAYS" />
                            <Button fx:id="btnConfirmar" onAction="#Confirmar" prefHeight="40" prefWidth="160" text="Confirmar Seleção" 
                                    style="-fx-background-color: #534AB7; -fx-background-radius: 8; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" />
                        </HBox>
                    </VBox>

                    <VBox VBox.vgrow="ALWAYS" style="-fx-background-color: #1a1f36; -fx-background-radius: 14; -fx-border-color: #252b4a; -fx-border-radius: 14;">
                        <HBox alignment="CENTER_LEFT" style="-fx-padding: 18 28; -fx-border-color: transparent transparent #252b4a transparent;">
                            <Label text="Base de Clientes" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #c5c8e8;" />
                        </HBox>
                        
                        <TableView fx:id="tabCliente" VBox.vgrow="ALWAYS" styleClass="tabela-sistema"
                                   style="-fx-background-color: transparent; -fx-control-inner-background: #1a1f36; -fx-control-inner-background-alt: #1d2239; -fx-table-cell-border-color: #1e2540;">
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="70" text="ID" style="-fx-alignment: CENTER;" />
                                <TableColumn fx:id="colNome" prefWidth="250" text="Nome Completo" />
                                <TableColumn fx:id="colCpf" prefWidth="150" text="CPF" style="-fx-alignment: CENTER;" />
                                <TableColumn fx:id="colEmail" prefWidth="200" text="E-mail" />
                                <TableColumn fx:id="colStatus" prefWidth="120" text="Status" style="-fx-alignment: CENTER;" />
                            </columns>
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                        </TableView>
                    </VBox>
                </VBox>
            </center>
        </BorderPane>
    </children>
</StackPane>