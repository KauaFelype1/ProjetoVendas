<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="720.0" prefWidth="1100.0" style="-fx-background-color: #0f1120;" stylesheets="@../login.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.controller.CaixaRegistradoraController">
   <children>
      <BorderPane>
         <top>
            <VBox style="-fx-padding: 20 40 10 40;">
               <HBox alignment="CENTER_LEFT">
                  <VBox>
                     <Label text="PONTO DE VENDA" style="-fx-font-size: 10px; -fx-text-fill: #534AB7; -fx-font-weight: bold; -fx-letter-spacing: 2;" />
                     <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="Caixa" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #c5c8e8;" />
                        <Label text="Livre" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #534AB7;" />
                     </HBox>
                  </VBox>
                  <Pane HBox.hgrow="ALWAYS" />
                  <VBox alignment="CENTER_RIGHT" style="-fx-background-color: #1a1f36; -fx-padding: 10 20; -fx-background-radius: 12; -fx-border-color: #252b4a; -fx-border-radius: 12;">
                     <Label text="CLIENTE SELECIONADO" style="-fx-font-size: 9px; -fx-text-fill: #6b7099; -fx-font-weight: bold;" />
                     <Label fx:id="lblNome" text="Consumidor Final" style="-fx-font-size: 14px; -fx-text-fill: white; -fx-font-weight: bold;" />
                  </VBox>
               </HBox>
               <Region prefHeight="1" style="-fx-background-color: #1e2540;">
                  <VBox.margin><Insets top="15" /></VBox.margin>
               </Region>
            </VBox>
         </top>

         <center>
            <HBox spacing="25" style="-fx-padding: 10 40 30 40;">
               <VBox spacing="20" HBox.hgrow="ALWAYS">
                  <VBox spacing="15" style="-fx-background-color: #1a1f36; -fx-padding: 20; -fx-background-radius: 14; -fx-border-color: #252b4a; -fx-border-radius: 14;">
                     <Label text="ADICIONAR PRODUTO" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #c5c8e8;" />
                     <HBox spacing="10">
                        <TextField fx:id="txtProduto" HBox.hgrow="ALWAYS" prefHeight="45" promptText="Escaneie o código ou digite o nome..." style="-fx-background-color: #0d1028; -fx-border-color: #252b4a; -fx-background-radius: 8; -fx-text-fill: white;" />
                        <Button onAction="#buscar" prefHeight="45" prefWidth="100" text="Buscar" style="-fx-background-color: #252b4a; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 8;" />
                     </HBox>
                     <HBox spacing="15" alignment="BOTTOM_LEFT">
                        <VBox spacing="5">
                           <Label text="QUANTIDADE" style="-fx-font-size: 9px; -fx-text-fill: #6b7099;" />
                           <TextField fx:id="txtQuantidade" prefHeight="45" prefWidth="100" text="1" style="-fx-background-color: #0d1028; -fx-border-color: #252b4a; -fx-alignment: CENTER; -fx-font-weight: bold; -fx-text-fill: white;" />
                        </VBox>
                        <Button fx:id="btnAddCarrinho" onAction="#adicionarCarrinho" prefHeight="45" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS" text="ADICIONAR AO CARRINHO" style="-fx-background-color: #534AB7; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 8;" />
                     </HBox>
                  </VBox>

                  <VBox VBox.vgrow="ALWAYS" style="-fx-background-color: #1a1f36; -fx-background-radius: 14; -fx-border-color: #252b4a; -fx-border-radius: 14;">
                     <TableView fx:id="tabProduto" VBox.vgrow="ALWAYS" styleClass="tabela-sistema" style="-fx-background-color: transparent;">
                        <columns>
                           <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                           <TableColumn fx:id="colNome" prefWidth="150.0" text="Produto" />
                           <TableColumn fx:id="colCategoria" prefWidth="120.0" text="Categoria" />
                           <TableColumn fx:id="colQuantidade" prefWidth="80.0" text="Estoque" />
                           <TableColumn fx:id="colPreco" prefWidth="90.0" text="Preço" />
                        </columns>
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                     </TableView>
                  </VBox>

                  <VBox spacing="15" style="-fx-background-color: #1a1f36; -fx-padding: 20; -fx-background-radius: 14; -fx-border-color: #252b4a; -fx-border-radius: 14;">
                     <Label text="PAGAMENTO" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #c5c8e8;" />
                     <HBox spacing="10">
                        <MenuButton fx:id="menuPagamento" prefHeight="45" prefWidth="160" text="Forma de Pagamento" style="-fx-background-color: #0d1028; -fx-border-color: #252b4a; -fx-text-fill: #c5c8e8; -fx-background-radius: 8;">
                           <items>
                              <MenuItem fx:id="itemDinheiro" text="Dinheiro" />
                              <MenuItem fx:id="itemCartaoDebito" text="Cartão Débito" />
                              <MenuItem fx:id="itemCartaoCredito" text="Cartão Crédito" />
                              <MenuItem fx:id="itemPix" text="Pix" />
                           </items>
                        </MenuButton>
                        <TextField fx:id="txtValorPago" prefHeight="45" HBox.hgrow="ALWAYS" promptText="R$ 0,00" style="-fx-background-color: #0d1028; -fx-border-color: #252b4a; -fx-text-fill: #00ff88; -fx-font-size: 16px; -fx-font-weight: bold;" />
                        <Button onAction="#adicionarPagamento" prefHeight="45" prefWidth="120" text="Confirmar" style="-fx-background-color: #252b4a; -fx-text-fill: white; -fx-font-weight: bold;" />
                     </HBox>
                     <ListView fx:id="listPagamentos" prefHeight="80" style="-fx-background-color: #0d1028; -fx-background-radius: 8; -fx-border-color: #252b4a;" />
                  </VBox>
               </VBox>

               <VBox spacing="20" prefWidth="420">
                  <VBox VBox.vgrow="ALWAYS" style="-fx-background-color: #1a1f36; -fx-background-radius: 14; -fx-border-color: #252b4a; -fx-border-radius: 14;">
                     <HBox style="-fx-padding: 15; -fx-border-color: transparent transparent #252b4a transparent;">
                        <Label text="Itens no Carrinho" style="-fx-text-fill: #c5c8e8; -fx-font-weight: bold;" />
                        <Pane HBox.hgrow="ALWAYS" />
                        <Button onAction="#removerItem" text="Excluir Item" style="-fx-background-color: transparent; -fx-text-fill: #ff4d4d; -fx-font-size: 11px; -fx-cursor: hand;" />
                     </HBox>
                     <TableView fx:id="tabCarrinho" VBox.vgrow="ALWAYS" styleClass="tabela-sistema" style="-fx-background-color: transparent;">
   <columns>
      <TableColumn fx:id="colCarNome" prefWidth="150" text="Item" />
      <TableColumn fx:id="colCarQtd" prefWidth="50" text="Qtd" />
      <TableColumn fx:id="colCarPreco" prefWidth="80" text="Preço Un." /> <TableColumn fx:id="colCarSubtotal" prefWidth="90" text="Subtotal" />
   </columns>
   <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
</TableView>
                  </VBox>

                  <VBox spacing="12" style="-fx-background-color: #1a1f36; -fx-padding: 25; -fx-background-radius: 14; -fx-border-color: #252b4a; -fx-border-radius: 14;">
                     <HBox alignment="CENTER_LEFT">
                        <Label text="SUBTOTAL" style="-fx-text-fill: #6b7099; -fx-font-size: 12px;" />
                        <Pane HBox.hgrow="ALWAYS" />
                        <Label fx:id="lblTotal" text="R$ 0,00" style="-fx-text-fill: #c5c8e8; -fx-font-size: 16px;" />
                     </HBox>
                     <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="DESCONTO %" style="-fx-text-fill: #6b7099; -fx-font-size: 12px;" />
                        <TextField fx:id="txtDesconto" prefWidth="60" text="0" style="-fx-background-color: #0d1028; -fx-border-color: #252b4a; -fx-text-fill: white;" />
                        <Button onAction="#aplicarDesconto" text="OK" style="-fx-background-color: #252b4a; -fx-text-fill: white;" />
                        <Pane HBox.hgrow="ALWAYS" />
                        <Label fx:id="lblTotalComDesconto" text="R$ 0,00" style="-fx-text-fill: #00ff88; -fx-font-size: 16px; -fx-font-weight: bold;" />
                     </HBox>
                     <Region prefHeight="1" style="-fx-background-color: #252b4a;" />
                     <HBox alignment="CENTER_LEFT">
                        <Label text="TROCO" style="-fx-text-fill: #6b7099; -fx-font-size: 12px;" />
                        <Pane HBox.hgrow="ALWAYS" />
                        <Label fx:id="lblTroco" text="R$ 0,00" style="-fx-text-fill: #ffcc00; -fx-font-size: 20px; -fx-font-weight: bold;" />
                     </HBox>
                     <VBox spacing="10" style="-fx-padding: 10 0 0 0;">
                        <Button fx:id="btnFinalizar" onAction="#finalizarVenda" maxWidth="1.7976931348623157E308" prefHeight="55" text="FINALIZAR VENDA" style="-fx-background-color: #00ff88; -fx-text-fill: #0d1028; -fx-font-weight: bold; -fx-font-size: 16px; -fx-background-radius: 10; -fx-cursor: hand;" />
                        <Button onAction="#cancelar" maxWidth="1.7976931348623157E308" prefHeight="35" text="CANCELAR" style="-fx-background-color: transparent; -fx-border-color: #ff4d4d; -fx-text-fill: #ff4d4d; -fx-background-radius: 10; -fx-cursor: hand;" />
                     </VBox>
                  </VBox>
               </VBox>
            </HBox>
         </center>
      </BorderPane>
   </children>
</StackPane>