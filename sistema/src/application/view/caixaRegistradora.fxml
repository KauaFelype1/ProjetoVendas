<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane
    maxHeight="1.7976931348623157E308"
    maxWidth="1.7976931348623157E308"
    style="-fx-background-color: #0f1120;"
    stylesheets="@../login.css"
    xmlns="http://javafx.com/javafx/25"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="application.controller.CaixaRegistradoraController">

    <children>
        <BorderPane
            maxHeight="1.7976931348623157E308"
            maxWidth="1.7976931348623157E308"
            style="-fx-background-color: #0f1120;">

            <!-- ══════════════════ TOPBAR ══════════════════ -->
            <top>
                <VBox style="-fx-background-color: #13192e;
                             -fx-border-color: transparent transparent #1e2540 transparent;
                             -fx-border-width: 0 0 1 0;
                             -fx-padding: 12 28 12 28; -fx-spacing: 10;">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Button fx:id="btnVoltar" onAction="#cancelar"
                                text="← Voltar" prefHeight="32"
                                style="-fx-background-color: transparent;
                                       -fx-border-color: #2a3156; -fx-border-radius: 7;
                                       -fx-border-width: 1.5; -fx-text-fill: #8891bb;
                                       -fx-font-size: 12px; -fx-cursor: hand;
                                       -fx-padding: 0 14 0 14;" />
                        <Label text="Vendas"
                               style="-fx-font-size: 12px; -fx-text-fill: #6b7099;" />
                        <Label text="›"
                               style="-fx-font-size: 13px; -fx-text-fill: #3a4060;" />
                        <Label text="Caixa Registradora"
                               style="-fx-font-size: 12px; -fx-text-fill: #534AB7;
                                      -fx-font-weight: bold;" />
                    </HBox>
                </VBox>
            </top>

            <!-- ══════════════════ CORPO PRINCIPAL ══════════════════ -->
            <center>
                <HBox maxHeight="1.7976931348623157E308"
                      maxWidth="1.7976931348623157E308">

                    <!-- ════════ COLUNA ESQUERDA — Busca + Produtos ════════ -->
                    <VBox prefWidth="520"
                          maxHeight="1.7976931348623157E308"
                          style="-fx-background-color: #0f1120;
                                 -fx-border-color: transparent #1e2540 transparent transparent;
                                 -fx-border-width: 0 1 0 0;
                                 -fx-padding: 20 20 20 28;
                                 -fx-spacing: 14;">

                        <!-- CHIP CLIENTE -->
                        <HBox alignment="CENTER_LEFT" spacing="14"
                              style="-fx-background-color: #1a1f36;
                                     -fx-background-radius: 10;
                                     -fx-border-color: #252b4a;
                                     -fx-border-radius: 10;
                                     -fx-border-width: 0 0 0 3;
                                     -fx-border-color: #534AB7 transparent transparent transparent;
                                     -fx-border-width: 0 0 0 3;
                                     -fx-padding: 12 18 12 18;">
                            <VBox spacing="3">
                                <Label text="CLIENTE"
                                       style="-fx-font-size: 9px; -fx-font-weight: bold;
                                              -fx-text-fill: #534AB7;
                                              -fx-letter-spacing: 1px;" />
                                <Label fx:id="lblNome" text="Nenhum cliente selecionado"
                                       style="-fx-font-size: 15px; -fx-font-weight: bold;
                                              -fx-text-fill: white;" />
                            </VBox>
                        </HBox>

                        <!-- BUSCA -->
                        <VBox spacing="7">
                            <Label text="BUSCAR PRODUTO"
                                   style="-fx-font-size: 10px; -fx-font-weight: bold;
                                          -fx-text-fill: #6b7099;" />
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <TextField fx:id="txtProduto"
                                           promptText="Nome ou código de barras"
                                           HBox.hgrow="ALWAYS"
                                           onAction="#buscar"
                                           style="-fx-background-color: #0d1028;
                                                  -fx-background-radius: 9;
                                                  -fx-border-color: #252b4a;
                                                  -fx-border-radius: 9;
                                                  -fx-border-width: 1.5;
                                                  -fx-text-fill: #c5c8e8;
                                                  -fx-prompt-text-fill: #3a4060;
                                                  -fx-font-size: 13px;
                                                  -fx-pref-height: 42px;
                                                  -fx-padding: 0 16 0 16;" />
                                <Button fx:id="btnBuscarProduto" onAction="#buscar"
                                        text="Buscar" prefHeight="42" prefWidth="100"
                                        style="-fx-background-color: #252b4a;
                                               -fx-background-radius: 9;
                                               -fx-text-fill: #c5c8e8;
                                               -fx-font-size: 13px;
                                               -fx-font-weight: bold;
                                               -fx-cursor: hand;" />
                            </HBox>
                        </VBox>

                        <!-- QUANTIDADE + ADICIONAR -->
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <VBox spacing="7">
                                <Label text="QUANTIDADE"
                                       style="-fx-font-size: 10px; -fx-font-weight: bold;
                                              -fx-text-fill: #6b7099;" />
                                <TextField fx:id="txtQuantidade" text="1"
                                           style="-fx-background-color: #0d1028;
                                                  -fx-background-radius: 9;
                                                  -fx-border-color: #252b4a;
                                                  -fx-border-radius: 9;
                                                  -fx-border-width: 1.5;
                                                  -fx-text-fill: #c5c8e8;
                                                  -fx-font-size: 13px;
                                                  -fx-pref-height: 42px;
                                                  -fx-pref-width: 80px;
                                                  -fx-padding: 0 16 0 16;" />
                            </VBox>
                            <Button fx:id="btnAddCarrinho" onAction="#adicionarCarrinho"
                                    text="+ Adicionar ao Carrinho"
                                    prefHeight="42"
                                    style="-fx-background-color: #534AB7;
                                           -fx-background-radius: 9;
                                           -fx-text-fill: white;
                                           -fx-font-size: 13px;
                                           -fx-font-weight: bold;
                                           -fx-cursor: hand;
                                           -fx-padding: 0 20 0 20;"
                                    VBox.vgrow="NEVER">
                                <VBox.margin><Insets top="20" /></VBox.margin>
                            </Button>
                        </HBox>

                        <!-- TABELA DE PRODUTOS -->
                        <VBox VBox.vgrow="ALWAYS"
                              style="-fx-background-color: #1a1f36;
                                     -fx-background-radius: 12;
                                     -fx-border-color: #252b4a;
                                     -fx-border-radius: 12;">
                            <HBox alignment="CENTER_LEFT"
                                  style="-fx-padding: 14 20 14 20;
                                         -fx-border-color: transparent transparent #252b4a transparent;
                                         -fx-border-width: 0 0 1 0;">
                                <Label text="Produtos Disponíveis"
                                       style="-fx-font-size: 13px; -fx-font-weight: bold;
                                              -fx-text-fill: #c5c8e8;" />
                                <Label text=" — clique para selecionar"
                                       style="-fx-font-size: 11px; -fx-text-fill: #6b7099;" />
                            </HBox>
                            <TableView fx:id="tabProduto" VBox.vgrow="ALWAYS"
                                       styleClass="tabela-sistema"
                                       style="-fx-background-color: transparent;
                                              -fx-control-inner-background: #1a1f36;
                                              -fx-control-inner-background-alt: #1d2239;
                                              -fx-table-cell-border-color: #1e2540;
                                              -fx-border-color: transparent;">
                                <columns>
                                    <TableColumn fx:id="colId" text="ID" prefWidth="50"
                                                 style="-fx-alignment: CENTER;" />
                                    <TableColumn fx:id="colNome" text="Nome" prefWidth="160" />
                                    <TableColumn fx:id="colCategoria" text="Categoria" prefWidth="110" />
                                    <TableColumn fx:id="colQuantidade" text="Estoque" prefWidth="70"
                                                 style="-fx-alignment: CENTER;" />
                                    <TableColumn fx:id="colPreco" text="Preço" prefWidth="90"
                                                 style="-fx-alignment: CENTER_RIGHT;" />
                                </columns>
                                <placeholder>
                                    <Label text="Nenhum produto encontrado."
                                           style="-fx-text-fill: #6b7099; -fx-font-size: 13px;" />
                                </placeholder>
                            </TableView>
                        </VBox>

                    </VBox>

                    <!-- ════════ COLUNA DIREITA — Carrinho + Pagamento ════════ -->
                    <VBox HBox.hgrow="ALWAYS"
                          maxHeight="1.7976931348623157E308"
                          style="-fx-background-color: #0f1120;">

                        <!-- HEADER CARRINHO -->
                        <HBox alignment="CENTER_LEFT" spacing="12"
                              style="-fx-background-color: #13192e;
                                     -fx-border-color: transparent transparent #1e2540 transparent;
                                     -fx-border-width: 0 0 1 0;
                                     -fx-padding: 14 20 14 20;">
                            <Label text="Carrinho"
                                   style="-fx-font-size: 14px; -fx-font-weight: bold;
                                          -fx-text-fill: #c5c8e8;" />
                            <Pane HBox.hgrow="ALWAYS" />
                            <Button fx:id="btnRemover" onAction="#removerItem"
                                    text="Remover selecionado"
                                    style="-fx-background-color: transparent;
                                           -fx-border-color: #4a1e2a;
                                           -fx-border-radius: 8;
                                           -fx-border-width: 1.5;
                                           -fx-text-fill: #c06070;
                                           -fx-font-size: 11px;
                                           -fx-cursor: hand;
                                           -fx-padding: 5 12 5 12;" />
                        </HBox>

                        <!-- TABELA CARRINHO -->
                        <TableView fx:id="tabCarrinho" VBox.vgrow="ALWAYS"
                                   styleClass="tabela-sistema"
                                   style="-fx-background-color: transparent;
                                          -fx-control-inner-background: #0f1120;
                                          -fx-control-inner-background-alt: #121627;
                                          -fx-table-cell-border-color: #1e2540;
                                          -fx-border-color: transparent;">
                            <columns>
                                <TableColumn fx:id="colCarNome" text="Produto" prefWidth="150" />
                                <TableColumn fx:id="colCarQtd" text="Qtd" prefWidth="50"
                                             style="-fx-alignment: CENTER;" />
                                <TableColumn fx:id="colCarPreco" text="Unit." prefWidth="90"
                                             style="-fx-alignment: CENTER_RIGHT;" />
                                <TableColumn fx:id="colCarSubtotal" text="Subtotal" prefWidth="100"
                                             style="-fx-alignment: CENTER_RIGHT;" />
                            </columns>
                            <placeholder>
                                <Label text="Carrinho vazio."
                                       style="-fx-text-fill: #6b7099; -fx-font-size: 13px;" />
                            </placeholder>
                        </TableView>

                        <!-- ════ PAINEL DE PAGAMENTO ════ -->
                        <VBox style="-fx-background-color: #1a1f36;
                                     -fx-border-color: #252b4a transparent transparent transparent;
                                     -fx-border-width: 1 0 0 0;
                                     -fx-padding: 16 20 20 20;
                                     -fx-spacing: 12;">

                            <!-- TOTAIS -->
                            <HBox style="-fx-background-color: #0d1028;
                                         -fx-background-radius: 10;
                                         -fx-border-color: #1e2540;
                                         -fx-border-radius: 10;
                                         -fx-border-width: 1;
                                         -fx-padding: 12 16 12 16;"
                                  spacing="0">
                                <!-- Total bruto -->
                                <VBox spacing="3" HBox.hgrow="ALWAYS">
                                    <Label text="TOTAL"
                                           style="-fx-font-size: 9px; -fx-font-weight: bold;
                                                  -fx-text-fill: #6b7099;" />
                                    <Label fx:id="lblTotal" text="R$ 0,00"
                                           style="-fx-font-size: 16px; -fx-font-weight: bold;
                                                  -fx-text-fill: #c5c8e8;" />
                                </VBox>
                                <!-- Divisor -->
                                <Region prefWidth="1"
                                        style="-fx-background-color: #252b4a;"
                                        maxHeight="1.7976931348623157E308" />
                                <!-- Total com desconto -->
                                <VBox spacing="3" HBox.hgrow="ALWAYS"
                                      style="-fx-padding: 0 0 0 16;">
                                    <Label text="C/ DESCONTO"
                                           style="-fx-font-size: 9px; -fx-font-weight: bold;
                                                  -fx-text-fill: #6b7099;" />
                                    <Label fx:id="lblTotalComDesconto" text="R$ 0,00"
                                           style="-fx-font-size: 16px; -fx-font-weight: bold;
                                                  -fx-text-fill: #a09cff;" />
                                </VBox>
                                <!-- Divisor -->
                                <Region prefWidth="1"
                                        style="-fx-background-color: #252b4a;"
                                        maxHeight="1.7976931348623157E308" />
                                <!-- Troco -->
                                <VBox spacing="3" HBox.hgrow="ALWAYS"
                                      style="-fx-padding: 0 0 0 16;">
                                    <Label text="TROCO / FALTA"
                                           style="-fx-font-size: 9px; -fx-font-weight: bold;
                                                  -fx-text-fill: #6b7099;" />
                                    <Label fx:id="lblTroco" text="R$ 0,00"
                                           style="-fx-font-size: 16px; -fx-font-weight: bold;
                                                  -fx-text-fill: #4ecb8a;" />
                                </VBox>
                            </HBox>

                            <!-- DESCONTO -->
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="DESCONTO %"
                                       style="-fx-font-size: 10px; -fx-font-weight: bold;
                                              -fx-text-fill: #6b7099;" />
                                <TextField fx:id="txtDesconto" text="0"
                                           style="-fx-background-color: #0d1028;
                                                  -fx-background-radius: 8;
                                                  -fx-border-color: #252b4a;
                                                  -fx-border-radius: 8;
                                                  -fx-border-width: 1.5;
                                                  -fx-text-fill: #c5c8e8;
                                                  -fx-font-size: 13px;
                                                  -fx-pref-height: 36px;
                                                  -fx-pref-width: 65px;
                                                  -fx-padding: 0 10 0 10;" />
                                <Button fx:id="btnDesconto" onAction="#aplicarDesconto"
                                        text="Calcular" prefHeight="36"
                                        style="-fx-background-color: transparent;
                                               -fx-border-color: #2a3156;
                                               -fx-border-radius: 8;
                                               -fx-border-width: 1.5;
                                               -fx-text-fill: #8891bb;
                                               -fx-font-size: 12px;
                                               -fx-cursor: hand;
                                               -fx-padding: 0 14 0 14;" />
                            </HBox>

                            <!-- FORMA DE PAGAMENTO -->
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <MenuButton fx:id="menuPagamento" text="Forma de Pagamento"
                                            prefHeight="40"
                                            style="-fx-background-color: #252b4a;
                                                   -fx-background-radius: 9;
                                                   -fx-border-color: transparent;
                                                   -fx-text-fill: #c5c8e8;
                                                   -fx-font-size: 12px;
                                                   -fx-font-weight: bold;
                                                   -fx-cursor: hand;">
                                    <items>
                                        <MenuItem fx:id="itemDinheiro" text="Dinheiro" />
                                        <MenuItem fx:id="itemCartaoDebito" text="Cartão Débito" />
                                        <MenuItem fx:id="itemCartaoCredito" text="Cartão Crédito" />
                                        <MenuItem fx:id="itemPix" text="Pix" />
                                    </items>
                                </MenuButton>
                                <TextField fx:id="txtValorPago"
                                           promptText="Valor pago"
                                           HBox.hgrow="ALWAYS"
                                           style="-fx-background-color: #0d1028;
                                                  -fx-background-radius: 9;
                                                  -fx-border-color: #252b4a;
                                                  -fx-border-radius: 9;
                                                  -fx-border-width: 1.5;
                                                  -fx-text-fill: #c5c8e8;
                                                  -fx-prompt-text-fill: #3a4060;
                                                  -fx-font-size: 13px;
                                                  -fx-pref-height: 40px;
                                                  -fx-padding: 0 14 0 14;" />
                                <Button fx:id="btnAddPagamento" onAction="#adicionarPagamento"
                                        text="+ Adicionar" prefHeight="40"
                                        style="-fx-background-color: #252b4a;
                                               -fx-background-radius: 9;
                                               -fx-text-fill: #c5c8e8;
                                               -fx-font-size: 12px;
                                               -fx-font-weight: bold;
                                               -fx-cursor: hand;
                                               -fx-padding: 0 14 0 14;" />
                            </HBox>

                            <!-- LISTA DE PAGAMENTOS -->
                            <ListView fx:id="listPagamentos"
                                      prefHeight="80"
                                      style="-fx-background-color: #0d1028;
                                             -fx-background-radius: 9;
                                             -fx-border-color: #1e2540;
                                             -fx-border-radius: 9;
                                             -fx-border-width: 1;
                                             -fx-control-inner-background: #0d1028;
                                             -fx-text-fill: #c5c8e8;
                                             -fx-font-size: 12px;" />

                            <!-- BOTÕES FINAIS -->
                            <HBox spacing="10">
                                <Button fx:id="btnFinalizar" onAction="#finalizarVenda"
                                        text="Finalizar Venda"
                                        prefHeight="46" HBox.hgrow="ALWAYS"
                                        maxWidth="1.7976931348623157E308"
                                        style="-fx-background-color: #534AB7;
                                               -fx-background-radius: 10;
                                               -fx-text-fill: white;
                                               -fx-font-size: 14px;
                                               -fx-font-weight: bold;
                                               -fx-cursor: hand;" />
                                <Button fx:id="btnCancelar" onAction="#cancelar"
                                        text="Cancelar"
                                        prefHeight="46"
                                        style="-fx-background-color: transparent;
                                               -fx-border-color: #4a1e2a;
                                               -fx-border-radius: 10;
                                               -fx-border-width: 1.5;
                                               -fx-text-fill: #c06070;
                                               -fx-font-size: 13px;
                                               -fx-font-weight: bold;
                                               -fx-cursor: hand;
                                               -fx-padding: 0 24 0 24;" />
                            </HBox>

                        </VBox>
                    </VBox>
                </HBox>
            </center>
        </BorderPane>
    </children>
</StackPane>