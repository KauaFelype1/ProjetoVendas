<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="570.0" prefWidth="775.0"
           stylesheets="@../login.css"
           xmlns="http://javafx.com/javafx/25"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="application.controller.LoginController">
    <children>

        <Pane fx:id="fundoParticulas"
              maxHeight="1.7976931348623157E308"
              maxWidth="1.7976931348623157E308"
              style="-fx-background-color: #0f1120;" />

        <VBox alignment="CENTER"
              maxHeight="1.7976931348623157E308"
              maxWidth="1.7976931348623157E308">
            <children>
                <HBox fx:id="card" maxWidth="-Infinity" prefHeight="463.0" prefWidth="744.0">
                    <children>

                        <VBox alignment="CENTER" prefHeight="463.0" prefWidth="236.0"
                              spacing="0" styleClass="painel-esquerdo">
                            <children>
                                <ImageView fitHeight="133.0" fitWidth="194.0"
                                           pickOnBounds="true" preserveRatio="true">
                                    <image>
                                        <Image url="@../../resources/imagens/TradeSystem-removebg-preview.png" />
                                    </image>
                                    <VBox.margin><Insets bottom="20.0" /></VBox.margin>
                                </ImageView>
                                <Label styleClass="titulo-painel" text="Bem-vindo">
                                    <VBox.margin><Insets bottom="8.0" /></VBox.margin>
                                </Label>
                                <Label styleClass="subtitulo-painel"
                                       text="Faça login para continuar"
                                       wrapText="true" />
                            </children>
                        </VBox>

                        <VBox alignment="CENTER" prefHeight="463.0" prefWidth="525.0"
                              styleClass="painel-form">
                            <children>

                                <Label styleClass="titulo-form" text="Entrar na conta" />

                                <Label styleClass="subtitulo-form"
                                       text="Preencha suas credenciais">
                                    <VBox.margin><Insets bottom="24.0" /></VBox.margin>
                                </Label>

                                <VBox>
                                    <VBox.margin><Insets bottom="16.0" /></VBox.margin>
                                    <children>
                                        <Label styleClass="campo-label" text="USUÁRIO" />
                                        <HBox styleClass="campo-input"
                                              alignment="CENTER_LEFT" spacing="8">
                                            <children>
                                                <Label text="&#xf007;" styleClass="campo-icone" />
                                                <TextField fx:id="txtLogin"
                                                           promptText="Email do usuário"
                                                           styleClass="campo-input-interno">
                                                    <HBox.hgrow>
                                                        <Priority fx:constant="ALWAYS" />
                                                    </HBox.hgrow>
                                                </TextField>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <VBox>
                                    <VBox.margin><Insets bottom="24.0" /></VBox.margin>
                                    <children>
                                        <Label styleClass="campo-label" text="SENHA" />
                                        <HBox styleClass="campo-input"
                                              alignment="CENTER_LEFT" spacing="8">
                                            <children>
                                                <Label text="&#xf023;" styleClass="campo-icone" />
                                                <PasswordField fx:id="txtSenha"
                                                               promptText="Senha do usuário"
                                                               styleClass="campo-input-interno">
                                                    <HBox.hgrow>
                                                        <Priority fx:constant="ALWAYS" />
                                                    </HBox.hgrow>
                                                </PasswordField>
                                                <TextField fx:id="txtSenhaVisivel"
                                                           promptText="Senha do usuário"
                                                           styleClass="campo-input-interno"
                                                           visible="false" managed="false">
                                                    <HBox.hgrow>
                                                        <Priority fx:constant="ALWAYS" />
                                                    </HBox.hgrow>
                                                </TextField>
                                                <Label fx:id="btnMostrarSenha"
                                                       styleClass="campo-icone campo-icone-clicavel"
                                                       onMouseClicked="#toggleSenha" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <Button fx:id="btnEntrar" onAction="#Entrar"
                                        prefHeight="42.0" prefWidth="180.0"
                                        styleClass="btn-entrar" text="Entrar">
                                    <VBox.margin><Insets bottom="12.0" /></VBox.margin>
                                </Button>

                                <Label fx:id="lblNewUser"
                                       styleClass="link-novo"
                                       text="Novo Usuário" />

                            </children>
                        </VBox>

                    </children>
                </HBox>
            </children>
        </VBox>

    </children>
</StackPane>