<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane
    maxHeight="1.7976931348623157E308"
    maxWidth="1.7976931348623157E308"
    style="-fx-background-color: #0f1120;"
    stylesheets="@../login.css"
    xmlns="http://javafx.com/javafx/25"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="application.controller.CadastroProdutoController">

    <children>

        <BorderPane
            maxHeight="1.7976931348623157E308"
            maxWidth="1.7976931348623157E308"
            style="-fx-background-color: #0f1120;">

            <top>
                <VBox style="-fx-background-color: #0f1120; -fx-padding: 28 48 0 48; -fx-spacing: 10;">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Button fx:id="btnVoltar"
                                text="← Voltar"
                                prefHeight="32"
                                style="-fx-background-color: transparent;
                                       -fx-background-radius: 7;
                                       -fx-border-color: #2a3156;
                                       -fx-border-radius: 7;
                                       -fx-border-width: 1.5;
                                       -fx-text-fill: #8891bb;
                                       -fx-font-size: 12px;
                                       -fx-cursor: hand;
                                       -fx-padding: 0 14 0 14;" />
                        <Label text="Cadastros"
                               style="-fx-font-size: 12px; -fx-text-fill: #6b7099;" />
                        <Label text="›"
                               style="-fx-font-size: 13px; -fx-text-fill: #3a4060;" />
                        <Label text="Produtos"
                               style="-fx-font-size: 12px; -fx-text-fill: #534AB7; -fx-font-weight: bold;" />
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="0" style="-fx-padding: 6 0 0 0;">
                        <Label text="Cadastro"
                               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #c5c8e8;" />
                        <Label text=" de Produtos"
                               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #534AB7;" />
                        <Pane HBox.hgrow="ALWAYS" />
                        <Label text="Gerencie e cadastre seus produtos"
                               style="-fx-font-size: 13px; -fx-text-fill: #6b7099;" />
                    </HBox>

                    <Region prefHeight="1"
                            maxWidth="1.7976931348623157E308"
                            style="-fx-background-color: #1e2540;"
                            VBox.vgrow="NEVER">
                        <VBox.margin><Insets top="10" /></VBox.margin>
                    </Region>
                </VBox>
            </top>

            <center>
                <VBox
                    maxHeight="1.7976931348623157E308"
                    maxWidth="1.7976931348623157E308"
                    VBox.vgrow="ALWAYS"
                    style="-fx-padding: 24 48 36 48; -fx-spacing: 20; -fx-background-color: #0f1120;">

                    <VBox
                        style="-fx-background-color: #1a1f36;
                               -fx-background-radius: 14;
                               -fx-border-color: #252b4a;
                               -fx-border-radius: 14;
                               -fx-padding: 28 32 28 32;
                               -fx-spacing: 20;">

                        <HBox alignment="CENTER_LEFT" spacing="16">
                            <VBox spacing="7" HBox.hgrow="ALWAYS">
                                <Label text="BUSCAR PRODUTO"
                                       style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #6b7099;" />
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <TextField fx:id="txtBuscar"
                                               promptText="Digite o nome do produto"
                                               HBox.hgrow="ALWAYS"
                                               style="-fx-background-color: #0d1028;
                                                      -fx-background-radius: 9;
                                                      -fx-border-color: #252b4a;
                                                      -fx-border-radius: 9;
                                                      -fx-border-width: 1.5;
                                                      -fx-text-fill: #c5c8e8;
                                                      -fx-prompt-text-fill: #3a4060;
                                                      -fx-font-size: 13px;
                                                      -fx-pref-height: 48px;
                                                      -fx-padding: 0 16 0 16;" />
                                    <Button fx:id="btnBuscar"
                                            onAction="#Pesquisar"
                                            text="Buscar"
                                            prefHeight="48"
                                            prefWidth="120"
                                            style="-fx-background-color: #252b4a;
                                                   -fx-background-radius: 9;
                                                   -fx-text-fill: #c5c8e8;
                                                   -fx-font-size: 13px;
                                                   -fx-font-weight: bold;
                                                   -fx-cursor: hand;" />
                                    <Button fx:id="btnSugestao"
                                            onAction="#CalcularPreco"
                                            text="Sugestão de Preço"
                                            prefHeight="48"
                                            style="-fx-background-color: transparent;
                                                   -fx-background-radius: 9;
                                                   -fx-border-color: #2a3156;
                                                   -fx-border-radius: 9;
                                                   -fx-border-width: 1.5;
                                                   -fx-text-fill: #8891bb;
                                                   -fx-font-size: 13px;
                                                   -fx-cursor: hand;" />
                                </HBox>
                            </VBox>
                        </HBox>

                        <Region prefHeight="1"
                                maxWidth="1.7976931348623157E308"
                                style="-fx-background-color: #252b4a;" />

                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="Dados do Produto"
                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #c5c8e8;" />
                            <Label text="— preencha para cadastrar ou editar"
                                   style="-fx-font-size: 12px; -fx-text-fill: #6b7099;" />
                        </HBox>

                        <GridPane hgap="16" vgap="0" maxWidth="1.7976931348623157E308">
                            <columnConstraints>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="8" />
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="20" />
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="20" />
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="16" />
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="14" />
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="14" />
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="8" />
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints vgrow="NEVER" />
                            </rowConstraints>

                            <VBox spacing="7" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <Label text="ID"
                                       style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #6b7099;" />
                                <TextField fx:id="txtId"
                                           disable="true"
                                           editable="false"
                                           promptText="ID"
                                           maxWidth="1.7976931348623157E308"
                                           style="-fx-background-color: #0a0d1e;
                                                  -fx-background-radius: 9;
                                                  -fx-border-color: #1e2340;
                                                  -fx-border-radius: 9;
                                                  -fx-border-width: 1.5;
                                                  -fx-text-fill: #6b7099;
                                                  -fx-prompt-text-fill: #3a4060;
                                                  -fx-font-size: 13px;
                                                  -fx-pref-height: 48px;
                                                  -fx-padding: 0 16 0 16;" />
                            </VBox>

                            <VBox spacing="7" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <Label text="NOME"
                                       style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #6b7099;" />
                                <TextField fx:id="txtNome"
                                           promptText="Nome do produto"
                                           maxWidth="1.7976931348623157E308"
                                           style="-fx-background-color: #0d1028;
                                                  -fx-background-radius: 9;
                                                  -fx-border-color: #252b4a;
                                                  -fx-border-radius: 9;
                                                  -fx-border-width: 1.5;
                                                  -fx-text-fill: #c5c8e8;
                                                  -fx-prompt-text-fill: #3a4060;
                                                  -fx-font-size: 13px;
                                                  -fx-pref-height: 48px;
                                                  -fx-padding: 0 16 0 16;" />
                            </VBox>

                            <VBox spacing="7" GridPane.columnIndex="2" GridPane.rowIndex="0">
                                <Label text="DESCRIÇÃO"
                                       style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #6b7099;" />
                                <TextField fx:id="txtDescricao"
                                           promptText="Descrição"
                                           maxWidth="1.7976931348623157E308"
                                           style="-fx-background-color: #0d1028;
                                                  -fx-background-radius: 9;
                                                  -fx-border-color: #252b4a;
                                                  -fx-border-radius: 9;
                                                  -fx-border-width: 1.5;
                                                  -fx-text-fill: #c5c8e8;
                                                  -fx-prompt-text-fill: #3a4060;
                                                  -fx-font-size: 13px;
                                                  -fx-pref-height: 48px;
                                                  -fx-padding: 0 16 0 16;" />
                            </VBox>

                            <VBox spacing="7" GridPane.columnIndex="3" GridPane.rowIndex="0">
                                <Label text="CATEGORIA"
                                       style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #6b7099;" />
                                <TextField fx:id="txtCategoria"
                                           promptText="Categoria"
                                           maxWidth="1.7976931348623157E308"
                                           style="-fx-background-color: #0d1028;
                                                  -fx-background-radius: 9;
                                                  -fx-border-color: #252b4a;
                                                  -fx-border-radius: 9;
                                                  -fx-border-width: 1.5;
                                                  -fx-text-fill: #c5c8e8;
                                                  -fx-prompt-text-fill: #3a4060;
                                                  -fx-font-size: 13px;
                                                  -fx-pref-height: 48px;
                                                  -fx-padding: 0 16 0 16;" />
                            </VBox>

                            <VBox spacing="7" GridPane.columnIndex="4" GridPane.rowIndex="0">
                                <Label text="PREÇO DE VENDA"
                                       style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #6b7099;" />
                                <TextField fx:id="txtPreco"
                                           promptText="0,00"
                                           maxWidth="1.7976931348623157E308"
                                           style="-fx-background-color: #0d1028;
                                                  -fx-background-radius: 9;
                                                  -fx-border-color: #252b4a;
                                                  -fx-border-radius: 9;
                                                  -fx-border-width: 1.5;
                                                  -fx-text-fill: #c5c8e8;
                                                  -fx-prompt-text-fill: #3a4060;
                                                  -fx-font-size: 13px;
                                                  -fx-pref-height: 48px;
                                                  -fx-padding: 0 16 0 16;" />
                            </VBox>

                            <VBox spacing="7" GridPane.columnIndex="5" GridPane.rowIndex="0">
                                <Label text="PREÇO DE CUSTO"
                                       style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #6b7099;" />
                                <TextField fx:id="txtPrecoComprado"
                                           promptText="0,00"
                                           maxWidth="1.7976931348623157E308"
                                           style="-fx-background-color: #0d1028;
                                                  -fx-background-radius: 9;
                                                  -fx-border-color: #252b4a;
                                                  -fx-border-radius: 9;
                                                  -fx-border-width: 1.5;
                                                  -fx-text-fill: #c5c8e8;
                                                  -fx-prompt-text-fill: #3a4060;
                                                  -fx-font-size: 13px;
                                                  -fx-pref-height: 48px;
                                                  -fx-padding: 0 16 0 16;" />
                            </VBox>

                            <VBox spacing="7" GridPane.columnIndex="6" GridPane.rowIndex="0">
                                <Label text="QTD"
                                       style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #6b7099;" />
                                <TextField fx:id="txtQuantidade"
                                           disable="true"
                                           editable="false"
                                           text="0"
                                           maxWidth="1.7976931348623157E308"
                                           style="-fx-background-color: #0a0d1e;
                                                  -fx-background-radius: 9;
                                                  -fx-border-color: #1e2340;
                                                  -fx-border-radius: 9;
                                                  -fx-border-width: 1.5;
                                                  -fx-text-fill: #6b7099;
                                                  -fx-prompt-text-fill: #3a4060;
                                                  -fx-font-size: 13px;
                                                  -fx-pref-height: 48px;
                                                  -fx-padding: 0 16 0 16;" />
                            </VBox>
                        </GridPane>

                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <VBox spacing="7" prefWidth="260">
                                <Label text="CÓDIGO DE BARRAS"
                                       style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #6b7099;" />
                                <TextField fx:id="txtCode"
                                           disable="true"
                                           editable="false"
                                           promptText="Gerado automaticamente"
                                           maxWidth="1.7976931348623157E308"
                                           style="-fx-background-color: #0a0d1e;
                                                  -fx-background-radius: 9;
                                                  -fx-border-color: #1e2340;
                                                  -fx-border-radius: 9;
                                                  -fx-border-width: 1.5;
                                                  -fx-text-fill: #8891bb;
                                                  -fx-prompt-text-fill: #3a4060;
                                                  -fx-font-size: 12px;
                                                  -fx-pref-height: 44px;
                                                  -fx-padding: 0 16 0 16;" />
                            </VBox>
                            <Pane HBox.hgrow="ALWAYS" />
                            <Button fx:id="btnSalvar"
                                    onAction="#Salvar"
                                    text="Salvar Produto"
                                    prefHeight="44"
                                    prefWidth="180"
                                    style="-fx-background-color: #534AB7;
                                           -fx-background-radius: 9;
                                           -fx-text-fill: white;
                                           -fx-font-size: 13px;
                                           -fx-font-weight: bold;
                                           -fx-cursor: hand;" />
                            <Button fx:id="btnExcluir"
                                    onAction="#Excluir"
                                    text="Excluir Produto"
                                    prefHeight="44"
                                    prefWidth="160"
                                    style="-fx-background-color: transparent;
                                           -fx-background-radius: 9;
                                           -fx-border-color: #4a1e2a;
                                           -fx-border-radius: 9;
                                           -fx-border-width: 1.5;
                                           -fx-text-fill: #c06070;
                                           -fx-font-size: 13px;
                                           -fx-cursor: hand;" />
                        </HBox>
                    </VBox>

                    <VBox VBox.vgrow="ALWAYS"
                          style="-fx-background-color: #1a1f36;
                                 -fx-background-radius: 14;
                                 -fx-border-color: #252b4a;
                                 -fx-border-radius: 14;">

                        <HBox alignment="CENTER_LEFT"
                              style="-fx-padding: 18 28 18 28;
                                     -fx-border-color: transparent transparent #252b4a transparent;
                                     -fx-border-width: 0 0 1 0;">
                            <Label text="Produtos Cadastrados"
                                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #c5c8e8;" />
                            <Label text=" — clique em um registro para selecionar"
                                   style="-fx-font-size: 12px; -fx-text-fill: #6b7099;" />
                        </HBox>

                        <TableView fx:id="tabProduto"
                                   VBox.vgrow="ALWAYS"
                                   styleClass="tabela-sistema"
                                   style="-fx-background-color: transparent;
                                          -fx-control-inner-background: #1a1f36;
                                          -fx-control-inner-background-alt: #1d2239;
                                          -fx-table-cell-border-color: #1e2540;
                                          -fx-border-color: transparent;
                                          -fx-text-fill: #c5c8e8;
                                          -fx-font-size: 13px;">
                            <columns>
                                <TableColumn fx:id="colID" text="ID" prefWidth="80"
                                             style="-fx-alignment: CENTER;" />
                                <TableColumn fx:id="colNome" text="Nome" prefWidth="180" />
                                <TableColumn fx:id="colDescricao" text="Descrição" prefWidth="180" />
                                <TableColumn fx:id="colCategoria" text="Categoria" prefWidth="140" />
                                <TableColumn fx:id="colPreco" text="Preço" prefWidth="110"
                                             style="-fx-alignment: CENTER_RIGHT;" />
                                <TableColumn fx:id="colPrecoCusto" text="Preço de Custo" prefWidth="140"
                                             style="-fx-alignment: CENTER_RIGHT;" />
                                <TableColumn fx:id="colQuantidade" text="Qtd" prefWidth="80"
                                             style="-fx-alignment: CENTER;" />
                                <TableColumn fx:id="colCodigo" text="Código" prefWidth="150"
                                             style="-fx-alignment: CENTER;" />
                            </columns>
                            <placeholder>
                                <Label text="Nenhum produto cadastrado ainda."
                                       style="-fx-text-fill: #6b7099; -fx-font-size: 13px;" />
                            </placeholder>
                        </TableView>
                    </VBox>

                </VBox>
            </center>

        </BorderPane>

    </children>
</StackPane>
