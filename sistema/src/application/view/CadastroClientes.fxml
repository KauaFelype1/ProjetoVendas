<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane
    maxHeight="1.7976931348623157E308"
    maxWidth="1.7976931348623157E308"
    style="-fx-background-color: #0f1120;"
    stylesheets="@../login.css"
    xmlns="http://javafx.com/javafx/25"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="application.controller.CadastroClientesController">

    <children>

        <BorderPane
            maxHeight="1.7976931348623157E308"
            maxWidth="1.7976931348623157E308"
            style="-fx-background-color: #0f1120;">

            <top>
                <VBox style="-fx-background-color: #0f1120; -fx-padding: 28 48 0 48; -fx-spacing: 10;">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Button fx:id="btnVoltar"
                                text="← Voltar"
                                prefHeight="32"
                                style="-fx-background-color: transparent;
                                       -fx-background-radius: 7;
                                       -fx-border-color: #2a3156;
                                       -fx-border-radius: 7;
                                       -fx-border-width: 1.5;
                                       -fx-text-fill: #8891bb;
                                       -fx-font-size: 12px;
                                       -fx-cursor: hand;
                                       -fx-padding: 0 14 0 14;" />
                        <Label text="Cadastros"
                               style="-fx-font-size: 12px; -fx-text-fill: #6b7099;" />
                        <Label text="›"
                               style="-fx-font-size: 13px; -fx-text-fill: #3a4060;" />
                        <Label text="Clientes"
                               style="-fx-font-size: 12px; -fx-text-fill: #534AB7; -fx-font-weight: bold;" />
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="0" style="-fx-padding: 6 0 0 0;">
                        <Label text="Cadastro"
                               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #c5c8e8;" />
                        <Label text=" de Clientes"
                               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #534AB7;" />
                        <Pane HBox.hgrow="ALWAYS" />
                        <Label text="Gerencie e cadastre seus clientes"
                               style="-fx-font-size: 13px; -fx-text-fill: #6b7099;" />
                    </HBox>

                    <Region prefHeight="1"
                            maxWidth="1.7976931348623157E308"
                            style="-fx-background-color: #1e2540;"
                            VBox.vgrow="NEVER">
                        <VBox.margin><Insets top="10" /></VBox.margin>
                    </Region>
                </VBox>
            </top>

            <center>
                <VBox
                    maxHeight="1.7976931348623157E308"
                    maxWidth="1.7976931348623157E308"
                    VBox.vgrow="ALWAYS"
                    style="-fx-padding: 24 48 36 48; -fx-spacing: 20; -fx-background-color: #0f1120;">

                    <VBox
                        style="-fx-background-color: #1a1f36;
                               -fx-background-radius: 14;
                               -fx-border-color: #252b4a;
                               -fx-border-radius: 14;
                               -fx-padding: 28 32 28 32;
                               -fx-spacing: 20;">

                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="Novo Cliente"
                                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #c5c8e8;" />
                            <Label text="— preencha os dados abaixo"
                                   style="-fx-font-size: 12px; -fx-text-fill: #6b7099;" />
                        </HBox>

                        <GridPane hgap="20" vgap="0" maxWidth="1.7976931348623157E308">
                            <columnConstraints>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="25" />
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="25" />
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="25" />
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="25" />
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints vgrow="NEVER" />
                            </rowConstraints>

                            <VBox spacing="7" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <Label text="NOME COMPLETO"
                                       style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #6b7099;" />
                                <TextField fx:id="txtNome"
                                           promptText="Ex: João da Silva"
                                           maxWidth="1.7976931348623157E308"
                                           style="-fx-background-color: #0d1028;
                                                  -fx-background-radius: 9;
                                                  -fx-border-color: #252b4a;
                                                  -fx-border-radius: 9;
                                                  -fx-border-width: 1.5;
                                                  -fx-text-fill: #c5c8e8;
                                                  -fx-prompt-text-fill: #3a4060;
                                                  -fx-font-size: 13px;
                                                  -fx-pref-height: 48px;
                                                  -fx-padding: 0 16 0 16;" />
                            </VBox>

                            <VBox spacing="7" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <Label text="CPF"
                                       style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #6b7099;" />
                                <TextField fx:id="txtCPF"
                                           promptText="000.000.000-00"
                                           maxWidth="1.7976931348623157E308"
                                           style="-fx-background-color: #0d1028;
                                                  -fx-background-radius: 9;
                                                  -fx-border-color: #252b4a;
                                                  -fx-border-radius: 9;
                                                  -fx-border-width: 1.5;
                                                  -fx-text-fill: #c5c8e8;
                                                  -fx-prompt-text-fill: #3a4060;
                                                  -fx-font-size: 13px;
                                                  -fx-pref-height: 48px;
                                                  -fx-padding: 0 16 0 16;" />
                            </VBox>

                            <VBox spacing="7" GridPane.columnIndex="2" GridPane.rowIndex="0">
                                <Label text="EMAIL"
                                       style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #6b7099;" />
                                <TextField fx:id="txtEmail"
                                           promptText="email@exemplo.com"
                                           maxWidth="1.7976931348623157E308"
                                           style="-fx-background-color: #0d1028;
                                                  -fx-background-radius: 9;
                                                  -fx-border-color: #252b4a;
                                                  -fx-border-radius: 9;
                                                  -fx-border-width: 1.5;
                                                  -fx-text-fill: #c5c8e8;
                                                  -fx-prompt-text-fill: #3a4060;
                                                  -fx-font-size: 13px;
                                                  -fx-pref-height: 48px;
                                                  -fx-padding: 0 16 0 16;" />
                            </VBox>

                            <VBox spacing="7" GridPane.columnIndex="3" GridPane.rowIndex="0">
                                <Label text="SENHA"
                                       style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #6b7099;" />
                                <TextField fx:id="txtSenha"
                                           promptText="Senha de acesso"
                                           maxWidth="1.7976931348623157E308"
                                           style="-fx-background-color: #0d1028;
                                                  -fx-background-radius: 9;
                                                  -fx-border-color: #252b4a;
                                                  -fx-border-radius: 9;
                                                  -fx-border-width: 1.5;
                                                  -fx-text-fill: #c5c8e8;
                                                  -fx-prompt-text-fill: #3a4060;
                                                  -fx-font-size: 13px;
                                                  -fx-pref-height: 48px;
                                                  -fx-padding: 0 16 0 16;" />
                            </VBox>
                        </GridPane>

                        <HBox spacing="14" alignment="CENTER_LEFT">
                            <Button fx:id="btnSalvar"
                                    onAction="#salvar"
                                    text="Salvar Cliente"
                                    prefHeight="44"
                                    prefWidth="180"
                                    style="-fx-background-color: #534AB7;
                                           -fx-background-radius: 9;
                                           -fx-text-fill: white;
                                           -fx-font-size: 13px;
                                           -fx-font-weight: bold;
                                           -fx-cursor: hand;" />
                            <Button fx:id="btnUpdate"
                                    onAction="#AbrirUpdate"
                                    text="Modificar Dados"
                                    prefHeight="44"
                                    prefWidth="180"
                                    style="-fx-background-color: transparent;
                                           -fx-background-radius: 9;
                                           -fx-border-color: #2a3156;
                                           -fx-border-radius: 9;
                                           -fx-border-width: 1.5;
                                           -fx-text-fill: #8891bb;
                                           -fx-font-size: 13px;
                                           -fx-cursor: hand;" />
                        </HBox>
                    </VBox>

                    <VBox VBox.vgrow="ALWAYS"
                          style="-fx-background-color: #1a1f36;
                                 -fx-background-radius: 14;
                                 -fx-border-color: #252b4a;
                                 -fx-border-radius: 14;">

                        <HBox alignment="CENTER_LEFT"
                              style="-fx-padding: 18 28 18 28;
                                     -fx-border-color: transparent transparent #252b4a transparent;
                                     -fx-border-width: 0 0 1 0;">
                            <Label text="Clientes Cadastrados"
                                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #c5c8e8;" />
                        </HBox>

                        <TableView fx:id="tabCliente"
                                   VBox.vgrow="ALWAYS"
                                   styleClass="tabela-sistema"
                                   style="-fx-background-color: transparent;
                                          -fx-control-inner-background: #1a1f36;
                                          -fx-control-inner-background-alt: #1d2239;
                                          -fx-table-cell-border-color: #1e2540;
                                          -fx-border-color: transparent;
                                          -fx-text-fill: #c5c8e8;
                                          -fx-font-size: 13px;">
                            <columns>
                                <TableColumn fx:id="colIdCliente" text="ID" prefWidth="80"
                                             style="-fx-alignment: CENTER;" />
                                <TableColumn fx:id="colNome" text="Nome" prefWidth="220" />
                                <TableColumn fx:id="colCpf" text="CPF" prefWidth="170" />
                                <TableColumn fx:id="colEmail" text="Email" prefWidth="240" />
                                <TableColumn fx:id="colSenha" text="Senha" prefWidth="160" />
                                <TableColumn fx:id="colStatus" text="Status" prefWidth="130"
                                             style="-fx-alignment: CENTER;" />
                            </columns>
                            <placeholder>
                                <Label text="Nenhum cliente cadastrado ainda."
                                       style="-fx-text-fill: #6b7099; -fx-font-size: 13px;" />
                            </placeholder>
                        </TableView>
                    </VBox>

                </VBox>
            </center>

        </BorderPane>

    </children>
</StackPane>
